  "_notes": {
    "tou_elec_maps_to_ev_tou": "CEA's own rate mapping table maps BOTH EV-TOU and TOU-ELEC to its single EV-TOU rate, so tou-elec here carries the EV-TOU prices. This is CEA's stated mapping, not an assumption.",
    "dr_is_tiered": "SDG&E's DR is tiered but CEA publishes one flat 'Total' generation price for it, so both tiers carry the same number.",
    "gms_not_modeled": "CEA's schedule excludes SDG&E delivery, the PCIA exit fee, and a General Municipal Surcharge (GMS). The GMS is CEA's analogue of the franchise fee equivalent and is NOT in sdge.json's taxes_and_fees, which derived its 6.88% figure from an SDCP bill. A CEA bill may differ.",
    "not_modeled": "The schedule also carries Peak Smart Savers (-PK) event-day rates, a Solar Plus program, a Battery Bonus program, and a $0.06/kWh net surplus compensation rate. None are modeled.",
    "derived": "Clean Impact plus the published $0.00750/kWh 'Green Impact Premium - 100% Renewable' adder. Computed, not transcribed.",
    "no_rate_relief_credit": "The rate relief credit is not applied here — see rate_relief_scope_UNVERIFIED in cca-cea-clean-impact.json."
  },
  "nbt_generation_adder_per_kwh": 0.01,
  "nbt_generation_adder_source": "CEA Solar Impact (Solar Billing Plan): exports are credited at SDG&E's export price plus an additional $0.01/kWh. https://thecleanenergyalliance.org/solar-impact/",
  "nbt_generation_adder_notes": {
    "base_is_sdges": "CEA matches SDG&E's export credit pricing and pays a premium on top, so the base comes from rates/nbt-export.json.",
    "product_naming": "CEA routes solar customers to 'Solar Impact' (NEM 3.0) or 'Personal Impact' (NEM 2.0). Neither has its own generation price table — CEA's adopted rate schedule lists them only under net surplus compensation — so the generation prices in this file still apply.",
    "net_surplus": "CEA publishes a flat NSC of $0.06/kWh for Personal Impact / Solar Impact. Recorded here but not applied: SDG&E's and SDCP's equivalents are wholesale-indexed and vary, so paying out for one provider only would bias the comparison. Surplus is reported in kWh instead.",
    "net_surplus_compensation_per_kwh": 0.06
  },

